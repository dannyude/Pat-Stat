
# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://patstat:patstat_pass@localhost:5432/patstat_db
DATABASE_URL_SYNC=postgresql://patstat:patstat_pass@localhost:5432/patstat_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_URL=redis://localhost:6379/1
REDIS_SESSION_DB=2

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Firebase FCM ─────────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=/secrets/firebase-service-account.json
FCM_PROJECT_ID=your-firebase-project-id

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://app.patstat.com

# ─── Rate Limiting ────────────────────────────────────────────────────────────
API_RATE_LIMIT_DEFAULT=120/minute
AUTH_RATE_LIMIT=100/minute
WRITE_RATE_LIMIT=30/minute
